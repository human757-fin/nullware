{
  "name": "nullware",
  "version": "1.0.0",
  "description": "Security and developer-friendly web browser with minimal bloatware and built-in toggleable ad-blocker",
  "main": "tools/build.js",
  "scripts": {
    "build": "node tools/build.js",
    "build:debug": "node tools/build.js --debug",
    "build:release": "node tools/build.js --release",
    "clean": "node tools/clean.js",
    "test": "node tools/test.js",
    "download-deps": "node tools/clone_deps.js",
    "package": "node tools/package.js",
    "lint": "eslint tools/*.js",
    "precommit": "npm run lint"
  },
  "keywords": [
    "browser",
    "security",
    "privacy",
    "adblocker",
