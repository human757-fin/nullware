    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "axios": "^1.6.0",
    "fs-extra": "^11.1.1",
    "path": "^0.12.7",
    "child_process": "^1.0.2"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-node": "^11.1.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/human757-fin/nullware.git"
